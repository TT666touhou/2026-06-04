[gd_scene format=4 uid="uid://lobby_scene"]

[ext_resource type="Script" path="res://scripts/ui/lobby.gd" id="1_lobby"]

[node name="Lobby" type="Control"]
script = ExtResource("1_lobby")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.04, 0.04, 0.06, 1.0)

[node name="TitleBar" type="Label" parent="."]
anchor_right = 1.0
anchor_top = 0.05
anchor_bottom = 0.15
text = "◈ LOBBY ◈"
horizontal_alignment = 1
vertical_alignment = 1
add_theme_font_size_override("font_size", 20)
add_theme_color_override("font_color", Color(0.95, 0.95, 0.95, 1.0))

[node name="CenterContainer" type="CenterContainer" parent="."]
anchor_left = 0.15
anchor_right = 0.85
anchor_top = 0.15
anchor_bottom = 0.95

[node name="VBox" type="VBoxContainer" parent="CenterContainer"]
add_theme_constant_override("separation", 12)
size_flags_horizontal = 3

[node name="RoomCodeLabel" type="Label" parent="CenterContainer/VBox"]
text = "HOSTING..."
horizontal_alignment = 1
add_theme_font_size_override("font_size", 10)
add_theme_color_override("font_color", Color(0.5, 0.8, 1.0))

[node name="StatusLabel" type="Label" parent="CenterContainer/VBox"]
text = "Waiting for players..."
horizontal_alignment = 1
add_theme_font_size_override("font_size", 10)
add_theme_color_override("font_color", Color(0.7, 0.7, 0.7))

[node name="PlayerList" type="VBoxContainer" parent="CenterContainer/VBox"]
add_theme_constant_override("separation", 6)
size_flags_horizontal = 3

[node name="StartButton" type="Button" parent="CenterContainer/VBox"]
text = "[ START GAME ]"
custom_minimum_size = Vector2(240, 40)
add_theme_font_size_override("font_size", 14)
add_theme_color_override("font_color", Color(0.4, 1.0, 0.5))

[node name="BackButton" type="Button" parent="CenterContainer/VBox"]
text = "[ BACK TO TITLE ]"
custom_minimum_size = Vector2(240, 32)
add_theme_font_size_override("font_size", 11)
add_theme_color_override("font_color", Color(0.8, 0.5, 0.5))
