[gd_scene format=4 uid="uid://game_over_scene"]

[ext_resource type="Script" path="res://scripts/ui/game_over.gd" id="1_go"]

[node name="GameOver" type="Control"]
script = ExtResource("1_go")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.12, 0.02, 0.02, 0.95)

[node name="CenterContainer" type="CenterContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="CenterContainer"]
add_theme_constant_override("separation", 16)

[node name="TitleLabel" type="Label" parent="CenterContainer/VBox"]
text = "✖ GAME OVER ✖"
horizontal_alignment = 1
add_theme_font_size_override("font_size", 26)
add_theme_color_override("font_color", Color(1.0, 0.2, 0.2))

[node name="PlayerInfo" type="VBoxContainer" parent="CenterContainer/VBox"]
add_theme_constant_override("separation", 4)

[node name="RetryButton" type="Button" parent="CenterContainer/VBox"]
text = "[ RETRY ]"
custom_minimum_size = Vector2(200, 36)
add_theme_font_size_override("font_size", 13)

[node name="TitleButton" type="Button" parent="CenterContainer/VBox"]
text = "[ RETURN TO TITLE ]"
custom_minimum_size = Vector2(200, 36)
add_theme_font_size_override("font_size", 11)
