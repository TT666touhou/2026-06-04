[gd_scene format=4 uid="uid://victory_scene"]

[ext_resource type="Script" path="res://scripts/ui/victory.gd" id="1_v"]

[node name="Victory" type="Control"]
script = ExtResource("1_v")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.04, 0.1, 0.04, 0.96)

[node name="CenterContainer" type="CenterContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="CenterContainer"]
