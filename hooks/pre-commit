#!/bin/sh
# ==========================================================
# hooks/pre-commit
# AI-Agnostic Pre-Commit Hook for Godot 4 Project
#
# 適用範圍：任何 AI 模型（Claude、Gemini、GPT 等）以及人類開發者
# 觸發時機：每次執行 git commit 前自動執行
# 作用：  阻斷不符合規範的代碼進入 Git 歷史
# ==========================================================

set -e

echo ""
echo "============================================================"
echo "🔒 [Pre-Commit Hook] 開始執行代碼品質閘門..."
echo "============================================================"

# ——————————————————————————————————————
# [規則 1] 禁止提交 Godot 大型二進位資源而不通過 LFS
# ——————————————————————————————————————
echo "[1/3] 檢查大型檔案是否都已被 Git LFS 追蹤..."

# 找出 staged 中大於 5MB 的檔案
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | xargs -I{} sh -c 'test -f "{}" && stat -c "%s %n" "{}"' 2>/dev/null | awk '$1 > 5242880 {print $2}' || true)

if [ -n "$LARGE_FILES" ]; then
  echo "❌ [錯誤] 發現大型檔案未通過 LFS 追蹤，禁止提交！"
  echo "   以下檔案超過 5MB，請先執行 git lfs track 再 commit："
  echo "$LARGE_FILES"
  echo ""
  echo "   修復指令範例："
  echo '   git lfs track "*.glb"'
  echo "   git add .gitattributes"
  echo "   git add <your_file>"
  exit 1
fi
echo "   ✅ 所有大型檔案已正確追蹤"

# ——————————————————————————————————————
# [規則 2] Godot GDScript 靜態語法與型別安全檢查
# ——————————————————————————————————————
echo "[2/3] 執行 Godot 靜態語法檢查..."

# 確認是否有任何 .gd 檔案被修改
CHANGED_GD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' || true)

if [ -n "$CHANGED_GD" ]; then
  # 自動尋找 Godot 執行檔
  GODOT_BIN="C:/Users/88698/Downloads/Godot_v4.6.2-stable_win64.exe/Godot_v4.6.2-stable_win64.exe"

  if [ -f "$GODOT_BIN" ]; then
    "$GODOT_BIN" --headless --check-only --path . 2>&1
    GODOT_EXIT=$?
    if [ $GODOT_EXIT -ne 0 ]; then
      echo "❌ [錯誤] GDScript 語法或型別安全檢查失敗！阻斷 Commit。"
      echo "   請修復上方報告的 GDScript 錯誤後再重試。"
      exit 1
    fi
    echo "   ✅ GDScript 語法檢查通過"
  else
    echo "   ⚠️  找不到 Godot 執行檔，跳過語法檢查 (路徑: $GODOT_BIN)"
  fi
else
  echo "   ℹ️  本次無 .gd 檔案變更，跳過語法檢查"
fi

# ——————————————————————————————————————
# [規則 3] 禁止提交包含硬編碼機密或 API Key 的代碼
# ——————————————————————————————————————
echo "[3/3] 掃描敏感資訊洩露..."

# 掃描常見的機密洩露模式
STAGED_CONTENT=$(git diff --cached)
SECRETS_FOUND=0

# 偵測常見敏感字串模式
echo "$STAGED_CONTENT" | grep -iE '(api_key|apikey|secret_key|password|private_key|access_token)\s*=\s*["\x27][A-Za-z0-9+/]{20,}' && SECRETS_FOUND=1 || true

if [ $SECRETS_FOUND -eq 1 ]; then
  echo "❌ [錯誤] 偵測到疑似硬編碼的機密資訊（API Key / Password），阻斷 Commit！"
  echo "   請使用環境變數或設定檔管理機密，不可直接寫入代碼。"
  exit 1
fi
echo "   ✅ 未偵測到敏感資訊洩露"

# ——————————————————————————————————————
# 所有檢查通過
# ——————————————————————————————————————
echo ""
echo "============================================================"
echo "✅ 所有閘門通過！允許執行 Git Commit。"
echo "============================================================"
echo ""
exit 0
