#!/bin/sh
# ==========================================================
# hooks/pre-commit  (v4 — 全面強化版)
# AI-Agnostic + Role-Aware Pre-Commit Hook
#
# 觸發時機：每次 git commit 前
# v4 新增功能（2026-06-14）：
#   - 🚫 DEVELOPER 完全禁止直接 git commit 任何 .gd/.tscn/.tres
#     → Developer 必須透過 dev-submit.ps1 投遞給 Reviewer 審查佇列
#     → 只有 QA 角色可以執行最終 commit+push（唯一合法提交者）
#   - ⏱️ 時間限制警告（防卡死）：Reviewer≤30min, QA≤45min, Dev嘗試≤20min
#   - 所有現有 v3 功能保留
# ==========================================================

## ── 時間限制常數（供警告訊息使用）──
## REVIEWER 必須在 30 分鐘內完成審查
## QA 必須在 45 分鐘內完成測試
## Developer 每次嘗試上限 20 分鐘

set -e

echo ""
echo "============================================================"
echo "🔒 [Pre-Commit Hook v4] 角色感知驗證閘門..."
echo "============================================================"

# ——————————————————————————————————————
# 讀取目前角色
# ——————————————————————————————————————
ROLE="none"
if [ -f ".agent-role" ]; then
    ROLE=$(cat .agent-role | tr -d '\r\n\t ' | tr -cd 'a-z')
fi
echo "👤 目前角色：$ROLE"
echo ""

# ——————————————————————————————————————
# [通用規則 0] GAME_DESIGN.md 存在性檢查
# ——————————————————————————————————————
CHANGED_CODE=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
if [ -n "$CHANGED_CODE" ] && [ ! -f "docs/GAME_DESIGN.md" ]; then
    echo "❌ [設計前置檢查] 尚未建立 docs/GAME_DESIGN.md！"
    echo "   在寫任何代碼之前，Designer 必須先完成遊戲設計文件。"
    exit 1
fi

# ——————————————————————————————————————
# [通用規則 0b] GAME_DESIGN.md 只能由 Designer 修改
# ——————————————————————————————————————
GAME_DESIGN_CHANGED=$(git diff --cached --name-only | grep 'docs/GAME_DESIGN.md' || true)
if [ -n "$GAME_DESIGN_CHANGED" ] && [ "$ROLE" != "designer" ]; then
    echo "❌ [Designer 文件保護] docs/GAME_DESIGN.md 只能由 Designer 角色修改！"
    echo "   目前角色：$ROLE"
    exit 1
fi

# ——————————————————————————————————————
echo "[通用/1] 檢查大型檔案 LFS 追蹤..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read f; do
    if [ -f "$f" ]; then
        size=$(wc -c < "$f" 2>/dev/null || echo 0)
        if [ "$size" -gt 5242880 ]; then
            lfs_tracked=$(git check-attr filter -- "$f" 2>/dev/null | grep "filter: lfs" || true)
            if [ -z "$lfs_tracked" ]; then
                echo "$f"
            fi
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo "❌ 大型檔案未追蹤入 LFS，阻斷 Commit："
    echo "$LARGE_FILES"
    exit 1
fi
echo "   ✅ LFS 檢查通過"

# ——————————————————————————————————————
# [通用規則 1b] BOM 偵測與自動修復（.tscn / .tres / .gd）
# ——————————————————————————————————————
echo "[通用/1b] 偵測並移除 UTF-8 BOM，阻斷 UTF-16 BOM..."
BOM_FIXED=0
BOM_UTF16_FOUND=0
BOM_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres|godot)$' || true)
for f in $BOM_FILES; do
    if [ -f "$f" ]; then
        # 用 xxd 讀取前3個字節，判斷是否為 EF BB BF (UTF-8 BOM)
        HEADER3=$(head -c 3 "$f" | xxd -p 2>/dev/null || true)
        HEADER2=$(head -c 2 "$f" | xxd -p 2>/dev/null || true)
        if [ "$HEADER3" = "efbbbf" ]; then
            # UTF-8 BOM：自動移除
            TMP_FILE="${f}.nobom.tmp"
            dd if="$f" bs=1 skip=3 of="$TMP_FILE" 2>/dev/null
            mv "$TMP_FILE" "$f"
            git add "$f"
            echo "   🔧 已移除 UTF-8 BOM：$f"
            BOM_FIXED=$((BOM_FIXED + 1))
        elif [ "$HEADER2" = "fffe" ] || [ "$HEADER2" = "feff" ]; then
            # UTF-16 BOM：無法自動轉換，阻斷 Commit（ERR-011）
            echo "   ❌ UTF-16 BOM 偵測到（ERR-011）：$f"
            echo "      此文件使用 UTF-16 編碼，Godot 無法載入！"
            echo "      修復方法："
            echo "      PowerShell: \$b=[IO.File]::ReadAllBytes('\$f'); \$t=[Text.Encoding]::Unicode.GetString(\$b,2,\$b.Length-2); [IO.File]::WriteAllText('\$f',\$t,(New-Object Text.UTF8Encoding(\$false)))"
            BOM_UTF16_FOUND=$((BOM_UTF16_FOUND + 1))
        fi
    fi
done
if [ $BOM_UTF16_FOUND -gt 0 ]; then
    echo ""
    echo "❌ 發現 $BOM_UTF16_FOUND 個 UTF-16 BOM 文件，阻斷 Commit！"
    echo "   請先用 PowerShell 轉換為 UTF-8 無 BOM 格式（見上方修復方法）"
    exit 1
fi
if [ $BOM_FIXED -gt 0 ]; then
    echo "   ⚠️  已自動移除 $BOM_FIXED 個文件的 UTF-8 BOM（已重新 stage）"
else
    echo "   ✅ 無 BOM 問題"
fi

# ——————————————————————————————————————
# [通用規則 1c] .tscn 標頭格式驗證（ERR-023）
# 每個 .tscn 文件第一個有效字節必須是 '[' 
# PowerShell -replace 操作可能意外剝離開頭的 '[' 字符
# ——————————————————————————————————————
echo "[通用/1c] 驗證 .tscn 文件標頭格式（防止 ERR-023）..."
TSCN_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.tscn$' || true)
TSCN_HEADER_BROKEN=0
for f in $TSCN_FILES; do
    if [ -f "$f" ]; then
        # 使用 PowerShell 讀取第一個有效字節（跳過 BOM）
        FIRST_CHAR=$(powershell.exe -NoProfile -Command "
            \$bytes = [System.IO.File]::ReadAllBytes('$f')
            \$start = 0
            if (\$bytes.Length -ge 3 -and \$bytes[0] -eq 0xEF -and \$bytes[1] -eq 0xBB -and \$bytes[2] -eq 0xBF) { \$start = 3 }
            elseif (\$bytes.Length -ge 2 -and (\$bytes[0] -eq 0xFF -or \$bytes[0] -eq 0xFE)) { \$start = 2 }
            [char]\$bytes[\$start]
        " 2>/dev/null || echo "?")
        if [ "$FIRST_CHAR" != "[" ]; then
            echo "   ❌ ERR-023: $f 標頭損壞！第一個字符是 '$FIRST_CHAR'，應為 '['"
            echo "      修復：在文件開頭加入 '[' 字符"
            echo "      PowerShell: \$c=[IO.File]::ReadAllText('$f'); [IO.File]::WriteAllText('$f','['+\$c,(New-Object Text.UTF8Encoding(\$false)))"
            TSCN_HEADER_BROKEN=$((TSCN_HEADER_BROKEN + 1))
        fi
    fi
done
if [ $TSCN_HEADER_BROKEN -gt 0 ]; then
    echo ""
    echo "❌ 發現 $TSCN_HEADER_BROKEN 個 .tscn 文件標頭損壞，阻斷 Commit！"
    echo "   根本原因：PowerShell -replace 操作消耗了 '[' 字符（ERR-023）"
    echo "   最安全的修復：在 .tscn 文件第一行添加 '[' 前綴"
    exit 1
fi
echo "   ✅ 所有 .tscn 文件標頭格式正確"



# ——————————————————————————————————————
# [通用規則 2] 機密掃描
# ——————————————————————————————————————
echo "[通用/2] 掃描機密資訊洩露..."
STAGED_CONTENT=$(git diff --cached)
SECRETS_FOUND=0
echo "$STAGED_CONTENT" | grep -iE '(api_key|apikey|secret_key|password|private_key|access_token)\s*=\s*["'"'"'][A-Za-z0-9+/]{20,}' && SECRETS_FOUND=1 || true
if [ $SECRETS_FOUND -eq 1 ]; then
    echo "❌ 偵測到硬編碼機密，阻斷 Commit！"
    exit 1
fi
echo "   ✅ 機密掃描通過"

# ——————————————————————————————————————
# [通用規則 3] TODO/FIXME 新增行掃描（警告，不阻斷）
# ——————————————————————————————————————
echo "[通用/3] 掃描新增行中的 TODO/FIXME..."
STAGED_GD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' || true)
if [ -n "$STAGED_GD" ]; then
    TODO_FOUND=$(git diff --cached -- '*.gd' | grep '^+' | grep -v '^+++' | grep -iE '(TODO|FIXME|HACK|XXX)' || true)
    if [ -n "$TODO_FOUND" ]; then
        echo "⚠️  [警告] 新增代碼中包含 TODO/FIXME（不阻斷，但請留意）："
        echo "$TODO_FOUND" | head -10
    fi
fi
echo "   ✅ TODO 掃描完成"

# ——————————————————————————————————————
# [角色規則] Designer 專屬檢查
# ——————————————————————————————————————
if [ "$ROLE" = "designer" ]; then
    echo "[Designer/1] 驗證不包含代碼文件..."
    CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
    if [ -n "$CODE_FILES" ]; then
        echo "❌ [Designer 規則違反] Designer 不應提交代碼文件！"
        exit 1
    fi
    echo "   ✅ 無代碼文件，符合 Designer 規則"

    echo "[Designer/2] 驗證包含 GAME_DESIGN.md 的更新..."
    DESIGN_CHANGED=$(git diff --cached --name-only | grep 'docs/GAME_DESIGN.md' || true)
    if [ -z "$DESIGN_CHANGED" ]; then
        echo "⚠️  [Designer 警告] 此次提交未更新 GAME_DESIGN.md（5秒後繼續...）"
        sleep 5
    else
        echo "   ✅ GAME_DESIGN.md 已更新"
    fi

    echo "[Designer/3] 掃描 GAME_DESIGN.md 中的已知亂碼字元（GAP-001 修復）..."
    if [ -n "$DESIGN_CHANGED" ] && [ -f "docs/GAME_DESIGN.md" ]; then
        # 已知亂碼清單（ERR-DOC-001：PowerShell -replace 造成的中文字元損壞）
        # 正確字應為：留空、熔斷、稽核、截斷、渺茫→確認、種類→列出、頒布→發布
        CORRUPT_FOUND=$(powershell.exe -NoProfile -Command "
            \$content = [IO.File]::ReadAllText('docs/GAME_DESIGN.md')
            \$corrupts = @('疫空','燔斷','鄠核','酐断','渺認','種入','颁','涭','渺','鄠','酐','燔')
            \$found = @()
            foreach (\$c in \$corrupts) {
                if (\$content.Contains(\$c)) { \$found += \$c }
            }
            if (\$found.Count -gt 0) { 'CORRUPT:' + (\$found -join ',') } else { 'CLEAN' }
        " 2>/dev/null || echo "CHECK_FAILED")
        if echo "$CORRUPT_FOUND" | grep -q '^CORRUPT:'; then
            CHARS=$(echo "$CORRUPT_FOUND" | sed 's/^CORRUPT://')
            echo "❌ [ERR-DOC-001] GAME_DESIGN.md 含有已知亂碼字元：$CHARS"
            echo "   根本原因：使用了 PowerShell -replace 修改 .md 文件，\$1 展開為空值"
            echo "   修復方法：使用 replace_file_content 工具修復對應段落"
            echo "   禁止提交含亂碼的 GDD！"
            exit 1
        elif [ "$CORRUPT_FOUND" = "CHECK_FAILED" ]; then
            echo "   ⚠️  亂碼掃描跳過（PowerShell 不可用）"
        else
            echo "   ✅ GAME_DESIGN.md 無已知亂碼字元"
        fi
    else
        echo "   ℹ️  本次未修改 GAME_DESIGN.md，跳過亂碼掃描"
    fi
fi

# ——————————————————————————————————————
# [角色規則] Architect 專屬檢查
# ——————————————————————————————————————
if [ "$ROLE" = "architect" ]; then
    echo "[Architect/1] 驗證不包含代碼文件..."
    GD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
    if [ -n "$GD_FILES" ]; then
        echo "❌ [Architect 規則違反] Architect 不應提交代碼文件！"
        echo "$GD_FILES"
        exit 1
    fi
    echo "   ✅ 無代碼文件，符合 Architect 規則"

    echo "[Architect/2] 驗證 implementation_plan.md 已修改..."
    PLAN_CHANGED=$(git diff --cached --name-only | grep 'implementation_plan.md' || true)
    if [ -z "$PLAN_CHANGED" ]; then
        echo "⚠️  [Architect 警告] 此次提交未包含 implementation_plan.md（5秒後繼續...）"
        sleep 5
    else
        echo "   ✅ implementation_plan.md 已更新"
    fi

    echo "[Architect/3] 驗證 Autoload 順序（project.godot）..."
    if [ -f "project.godot" ]; then
        # 確認 DebugOverlay 在 DebugBridge 之前
        OVERLAY_LINE=$(grep -n "DebugOverlay" project.godot | head -1 | cut -d: -f1 || echo "0")
        BRIDGE_LINE=$(grep -n "DebugBridge" project.godot | head -1 | cut -d: -f1 || echo "0")
        if [ "$OVERLAY_LINE" -gt 0 ] && [ "$BRIDGE_LINE" -gt 0 ]; then
            if [ "$OVERLAY_LINE" -lt "$BRIDGE_LINE" ]; then
                echo "   ✅ Autoload 順序正確（DebugOverlay → DebugBridge）"
            else
                echo "⚠️  [Architect 警告] DebugOverlay 應在 DebugBridge 之前"
            fi
        fi
    fi
fi

# ——————————————————————————————————————
# [角色規則] Developer 專屬檢查
# 🚫 v4 新規則：Developer 禁止直接 git commit 任何代碼文件！
#    Developer 必須透過 dev-submit.ps1 投遞給 Reviewer。
#    只有 QA 角色可以執行最終 commit+push。
# ——————————————————————————————————————
if [ "$ROLE" = "developer" ]; then
    echo "[Developer/0] 🚫 v4 強制規則：Developer 不允許直接 git commit 代碼文件..."
    DEV_CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
    if [ -n "$DEV_CODE_FILES" ]; then
        echo ""
        echo "❌ ════════════════════════════════════════════════════════════"
        echo "❌  [Developer v4 規則違反] Developer 禁止直接 git commit 代碼！"
        echo "❌ ════════════════════════════════════════════════════════════"
        echo ""
        echo "  違規文件："
        echo "$DEV_CODE_FILES"
        echo ""
        echo "  ✅ 正確流程："
        echo "     1. 執行靜態驗證：Godot --check-only"
        echo "     2. 執行 Sensor 掃描：.\scripts\sensor-scan.ps1"
        echo "     3. 投遞給 Reviewer：.\scripts\dev-submit.ps1 -feature [功能名稱]"
        echo "     4. 等待 Reviewer 審查（限時 30 分鐘）"
        echo "     5. Reviewer 批准後，QA 執行最終測試並 commit"
        echo ""
        echo "  ⏱️  時間限制提醒："
        echo "     Developer 每次修復嘗試 ≤ 20 分鐘"
        echo "     若超時 → 熔斷，切換 architect role 求援"
        echo ""
        exit 1
    fi
    echo "   ✅ 無代碼文件（Developer 本次提交僅含文件，符合 v4 規則）"

    echo "[Developer/1] 執行 GDScript 語法驗證（非代碼文件提交略過）..."
    CHANGED_GD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' || true)

    if [ -n "$CHANGED_GD" ]; then
        GODOT_BIN="C:/Users/88698/Downloads/Godot_v4.6.2-stable_win64.exe/Godot_v4.6.2-stable_win64.exe"
        if [ -f "$GODOT_BIN" ]; then
            PROJECT_ROOT=$(git rev-parse --show-toplevel)
            VALIDATION_FAILED=0
            for gd_file in $CHANGED_GD; do
                RES_PATH="res://$(echo "$gd_file" | tr '\\' '/')"
                OUT=$(powershell.exe -NoProfile -Command "
                    \$p = Start-Process -FilePath '$GODOT_BIN' \`
                        -ArgumentList \"--headless\", \"--path\", '$PROJECT_ROOT', \"--check-only\", '$RES_PATH' \`
                        -PassThru -NoNewWindow -RedirectStandardOutput \$env:TEMP\godot_out.txt \`
                        -RedirectStandardError \$env:TEMP\godot_err.txt
                    if (-not \$p.WaitForExit(15000)) { \$p.Kill() }
                    (Get-Content \$env:TEMP\godot_out.txt -ErrorAction SilentlyContinue) +
                    (Get-Content \$env:TEMP\godot_err.txt -ErrorAction SilentlyContinue)
                " 2>&1)
                if echo "$OUT" | grep -qiE 'Parse Error|SCRIPT ERROR|error.*\.gd'; then
                    echo "❌ GDScript 語法錯誤：$gd_file"
                    echo "$OUT"
                    VALIDATION_FAILED=1
                fi
            done
            if [ $VALIDATION_FAILED -ne 0 ]; then
                echo "❌ GDScript 語法驗證失敗，阻斷 Commit！"
                exit 1
            fi
            echo "   ✅ GDScript 語法驗證通過"
        else
            echo "   ⚠️  找不到 Godot 執行檔，跳過語法驗證"
        fi
    else
        echo "   ℹ️  本次無 .gd 文件變更"
    fi

    echo "[Developer/2] 驗證在 feature 分支上提交..."
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
    if [ "$CURRENT_BRANCH" = "main" ]; then
        GD_IN_COMMIT=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' || true)
        if [ -n "$GD_IN_COMMIT" ]; then
            echo "❌ [Developer 規則違反] 禁止直接在 main 分支提交 .gd 代碼文件！"
            exit 1
        fi
    fi
    echo "   ✅ 分支檢查通過（目前：$CURRENT_BRANCH）"

    echo "[Developer/3] 驗證新增 .gd 文件有群組宣告（Debug 整合）..."
    NEW_GD=$(git diff --cached --name-only --diff-filter=A | grep '\.gd$' || true)
    if [ -n "$NEW_GD" ]; then
        for gd_file in $NEW_GD; do
            # 跳過 autoload 和 test 文件（不需要 group）
            case "$gd_file" in
                scripts/autoload/*|test/*|scripts/camera/*|scripts/ui/*|hooks/*)
                    continue
                    ;;
            esac
            # 檢查遊戲實體腳本是否有 add_to_group
            if echo "$gd_file" | grep -qE 'scripts/(player|enemy|npc)/'; then
                HAS_GROUP=$(grep 'add_to_group' "$gd_file" || true)
                if [ -z "$HAS_GROUP" ]; then
                    echo "⚠️  [Developer 警告] $gd_file 可能缺少 add_to_group()（DebugBridge 感知需要）"
                fi
            fi
        done
    fi
    echo "   ✅ Debug 整合初步驗證完成"

    echo "[Developer/4] 驗證 project.godot Autoload 一致性..."
    if git diff --cached --name-only | grep -q 'project.godot'; then
        # 確認 DebugOverlay 和 DebugBridge 都存在
        if [ -f "project.godot" ]; then
            HAS_OVERLAY=$(grep "DebugOverlay" project.godot || true)
            HAS_BRIDGE=$(grep "DebugBridge" project.godot || true)
            if [ -z "$HAS_OVERLAY" ] || [ -z "$HAS_BRIDGE" ]; then
                echo "⚠️  [Developer 警告] project.godot 缺少 DebugOverlay 或 DebugBridge Autoload"
            else
                echo "   ✅ Debug Autoload 存在"
            fi
        fi
    fi

    echo "[Developer/5] 驗證暫存的 TileSet .tres 有顯式 tile_size (ERR-031)..."
    CHANGED_TRES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.tres$' || true)
    if [ -n "$CHANGED_TRES" ]; then
        TILESET_MISSING=0
        for tres_file in $CHANGED_TRES; do
            if grep -q 'gd_resource type="TileSet"' "$tres_file" 2>/dev/null; then
                RESOURCE_SECTION=$(awk '/^\[resource\]/{found=1} found{print}' "$tres_file")
                if ! echo "$RESOURCE_SECTION" | grep -q 'tile_size'; then
                    echo "   ❌ [ERR-031] TileSet '$tres_file' 缺少 tile_size！"
                    echo "      在 [resource] 區塊加入: tile_size = Vector2i(W, H)"
                    TILESET_MISSING=1
                fi
            fi
        done
        if [ $TILESET_MISSING -eq 0 ]; then
            echo "   ✅ 所有暫存 TileSet .tres 均有 tile_size (ERR-031 通過)"
        else
            echo "   ⚠️  建議修復後再提交 (5秒後繼續...)"
            sleep 5
        fi
    else
        echo "   ℹ️  本次無 .tres 文件變更"
    fi
fi

# ——————————————————————————————————————
# [角色規則] Reviewer 專屬檢查
# ——————————————————————————————————————
if [ "$ROLE" = "reviewer" ]; then
    echo "[Reviewer/1] 驗證不包含代碼文件..."
    CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
    if [ -n "$CODE_FILES" ]; then
        echo "❌ [Reviewer 規則違反] Reviewer 不應提交代碼文件！"
        exit 1
    fi
    echo "   ✅ 無代碼文件，符合 Reviewer 規則"

    echo "[Reviewer/2] 驗證包含 docs/ 審查記錄..."
    REVIEW_DOCS=$(git diff --cached --name-only | grep 'docs/' || true)
    if [ -z "$REVIEW_DOCS" ]; then
        echo "⚠️  [Reviewer 警告] 此次提交未包含 docs/ 審查記錄（5秒後繼續...）"
        sleep 5
    else
        echo "   ✅ 審查記錄存在"
    fi
fi

# ——————————————————————————————————————
# [角色規則] QA 專屬檢查
# ——————————————————————————————————————
if [ "$ROLE" = "qa" ]; then
    echo "[QA/1] ✅ QA 是指定最終提交者，允許提交 .gd/.tscn/.tres（公告檢查）..."
    CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(gd|tscn|tres)$' || true)
    if [ -n "$CODE_FILES" ]; then
        echo "   ℹ️ QA 正在提交代碼文件（v4 合法：QA 是唯一最終提交者）"
        echo "   代碼文件："
        echo "$CODE_FILES"
        echo ""
        echo "   驗證：以下條件必須全部已滿足（QA 表示上述已完成）:"
        echo "   - Reviewer 已批准此 PR（APPROVE）"
        echo "   - QA 靜態驗證通過（--check-only 0 error）"
        echo "   - QA 執行 F6 場景驗證通過"
        echo "   - QA 執行實機驗證通過"
    fi

    echo "[QA/2] 驗證包含 QA 報告文件..."
    QA_REPORT=$(git diff --cached --name-only --diff-filter=ACM | grep 'docs/qa-report' || true)
    if [ -z "$QA_REPORT" ]; then
        echo "⚠️  [QA 警告] 此次提交未包含 QA 報告（docs/qa-report-*.md）（5秒後繼續...）"
        sleep 5
    else
        echo "   ✅ QA 報告已包含"
    fi

    echo "[QA/3] 驗證 debug_state.json 已存在（QA 必須親自執行遊戲）..."
    DEBUG_JSON_WIN=$(powershell.exe -NoProfile -Command "
        \$path = \"\$env:APPDATA\Godot\app_userdata\2026 06 04\debug_state.json\"
        if (Test-Path \$path) { 'EXISTS' } else { 'MISSING' }
    " 2>/dev/null || echo "CHECK_FAILED")
    
    if [ "$DEBUG_JSON_WIN" = "EXISTS" ]; then
        echo "   ✅ debug_state.json 存在（QA 確實執行了遊戲）"
    elif [ "$DEBUG_JSON_WIN" = "MISSING" ]; then
        echo "⚠️  [QA 警告] debug_state.json 不存在！"
        echo "   QA 必須執行遊戲（並按 F5 確認 DebugBridge 正常輸出）才能提交報告"
        echo "   (5秒後繼續，但請確認已執行遊戲測試...)"
        sleep 5
    else
        echo "   ℹ️  無法檢查 debug_state.json（PowerShell 不可用，跳過）"
    fi

    echo "[QA/4] 掃描 GAME_DESIGN.md 中未解決的 [GDD TODO]（GAP-008 修復）..."
    if [ -f "docs/GAME_DESIGN.md" ]; then
        # 注意：grep -c 在無匹配時 exit code=1，在 set -e 環境下需要防護
        GDD_TODO_COUNT=$(grep -c '\[GDD TODO\]' docs/GAME_DESIGN.md 2>/dev/null || true)
        GDD_TODO_COUNT="${GDD_TODO_COUNT:-0}"
        if [ "${GDD_TODO_COUNT}" -gt 0 ] 2>/dev/null; then
            echo "❌ [QA 規則違反] GAME_DESIGN.md 有 $GDD_TODO_COUNT 個未解決的 [GDD TODO]！"
            echo "   QA 不能通過！必須先請 Designer 更新對應章節。"
            echo "   未解決項目位置："
            grep -n '\[GDD TODO\]' docs/GAME_DESIGN.md | head -10
            exit 1
        else
            echo "   ✅ GAME_DESIGN.md 無未解決的 [GDD TODO]"
        fi
    else
        echo "   ⚠️  docs/GAME_DESIGN.md 不存在，跳過 GDD TODO 掃描"
    fi

    echo "[QA/5] ★ v4 強制：確認 F6 場景驗證已執行..."
    CHANGED_TSCN=$(git diff --cached --name-only --diff-filter=ACM | grep '\.tscn$' || true)
    if [ -n "$CHANGED_TSCN" ]; then
        echo "   ⚠️  本次提交包含以下 .tscn 場景，QA 必須確認已對每個執行 F6 測試："
        echo "$CHANGED_TSCN"
        echo ""
        echo "   F6 驗證清單（QA 提交前自我確認）："
        echo "   □ 每個 .tscn 用 F6 獨立開啟，確認玩家可正常出現"
        echo "   □ 鏡頭限制正確（不漂移到房間邊界外）"
        echo "   □ 玩家可正常操控和移動"
        echo "   □ Console 無 error（僅 warning 可接受）"
        echo "   □ F6 行為與 F5（透過 TITLE）一致"
        echo ""
        echo "   ⚠️  若任何項目未完成 → 退回 Developer 並說明原因（5秒後繼續...）"
        sleep 5
    else
        echo "   ℹ️  本次無 .tscn 場景變更，F6 驗證略過"
    fi

    echo ""
    echo "   ⏱️  QA 時間限制提醒：必須在 45 分鐘內完成所有測試（超時 → 退回 Developer）"
fi

# ——————————————————————————————————————
# [Developer fix: 提交 ERROR_LOG 提醒]
# ——————————————————————————————————————
if [ "$ROLE" = "developer" ]; then
    COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
    if [ -f "$COMMIT_MSG_FILE" ]; then
        COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" 2>/dev/null || echo "")
    else
        COMMIT_MSG=""
    fi
    # 若 staged message（透過 -m 傳遞）含 fix: 關鍵字，且 ERROR_LOG 未被修改
    STAGED_MSG=$(git log --format="%s" -1 2>/dev/null || echo "")
    if git diff --cached --name-only | grep -q 'fix\|Fix'; then
        ERROR_LOG_STAGED=$(git diff --cached --name-only | grep 'docs/ERROR_LOG.md' || true)
        if [ -z "$ERROR_LOG_STAGED" ]; then
            echo "⚠️  [Developer 提醒 GAP-003] 本次 commit 疑似包含 bug 修復，但 docs/ERROR_LOG.md 未更新"
            echo "   規則10：任何 ROLE 修復錯誤後必須更新 ERROR_LOG.md"
            echo "   （5秒後繼續，但請確認已更新 ERROR_LOG.md...）"
            sleep 5
        fi
    fi
fi

# ——————————————————————————————————————
# 全部通過
# ——————————————————————————————————————
echo ""
echo "============================================================"
echo "✅ 所有閘門通過！允許 Git Commit。[角色：$ROLE]"
echo "============================================================"
echo ""
exit 0
