#!/bin/sh
# ==========================================================
# hooks/commit-msg
# Commit 訊息格式驗證
#
# 觸發時機：git commit 訊息確認後
# 作用：強制 commit 訊息符合可追蹤的格式規範
# 格式：[ROLE] type: 描述
#       type 可以是：feat|fix|plan|review|test|docs|refactor|chore
# ==========================================================

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 跳過 merge commit
if echo "$COMMIT_MSG" | grep -q "^Merge"; then
    exit 0
fi

# 跳過 revert commit
if echo "$COMMIT_MSG" | grep -q "^Revert"; then
    exit 0
fi

# 允許的 type 列表
VALID_TYPES="feat|fix|plan|review|test|docs|refactor|chore|style|perf|ci"

# 允許的格式：
# 1. [ROLE] type: 描述 （有角色標籤）
# 2. type: 描述 （無角色標籤）
PATTERN_WITH_ROLE="^\[(ARCH|DEV|REVIEW|QA|DESIGN)\] ($VALID_TYPES): .{3,}"
PATTERN_WITHOUT_ROLE="^($VALID_TYPES): .{3,}"

FORMAT_OK=0
if echo "$COMMIT_MSG" | grep -qE "$PATTERN_WITH_ROLE"; then
    FORMAT_OK=1
elif echo "$COMMIT_MSG" | grep -qE "$PATTERN_WITHOUT_ROLE"; then
    FORMAT_OK=1
fi

# 格式不符合
if [ "$FORMAT_OK" -eq 0 ]; then
    echo ""
    echo "❌ [commit-msg] Commit 訊息格式不正確！"
    echo ""
    echo "   你的訊息：$COMMIT_MSG"
    echo ""
    echo "   正確格式：[ROLE] type: 描述 （至少 3 個字元）"
    echo "   範例："
    echo "     [ARCH] plan: 設計玩家移動系統架構 [Ponytail]"
    echo "     [DEV] feat: 實作玩家跳躍功能"
    echo "     [DEV] fix: 修正碰撞偵測在斜面上的錯誤"
    echo "     [REVIEW] review: 審查玩家移動 PR"
    echo "     [QA] test: 驗證玩家移動測試全部通過"
    echo "     docs: 更新 README [Ponytail]"
    echo ""
    echo "   可用 type: feat | fix | plan | review | test | docs | refactor | chore"
    echo ""
    exit 1
fi

# ==========================================================
# PONYTAIL 規則驗證 (Level 1)
# ==========================================================
PONYTAIL_MSG=$(echo "$COMMIT_MSG" | grep -i '\[Ponytail\]' || true)
if [ -z "$PONYTAIL_MSG" ]; then
    PONYTAIL_CODE=$(git diff --cached | grep -iE '^\+.*ponytail:' || true)
    if [ -z "$PONYTAIL_CODE" ]; then
        echo ""
        echo "❌ [commit-msg] 違反 GLOBAL-RULE-002: Ponytail 規則！"
        echo "   你必須在 Commit 訊息中加入 [Ponytail] 標籤"
        echo "   或在新增/修改的程式碼/文件中加入 'ponytail:' 註解。"
        echo "   例如：# ponytail: Rung 2, using AnimationPlayer"
        echo ""
        exit 1
    fi
fi

exit 0
