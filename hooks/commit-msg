#!/bin/sh
# ==========================================================
# hooks/commit-msg  (v2 — 格式驗證版)
# Commit 訊息格式驗證
#
# 觸發時機：git commit 訊息確認後
# v2: 移除 Ponytail 強制（2026-06-20 用戶決定移除）
# ==========================================================

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 跳過 merge commit
if echo "$COMMIT_MSG" | grep -q "^Merge"; then
    exit 0
fi

# 跳過 revert commit
if echo "$COMMIT_MSG" | grep -q "^Revert"; then
    exit 0
fi

# 允許的 type 列表
VALID_TYPES="feat|fix|plan|review|test|docs|refactor|chore|style|perf|ci"

# 允許的格式：
# 1. [ROLE] type: 描述 （有角色標籤）
# 2. type: 描述 （無角色標籤）
PATTERN_WITH_ROLE="^\[(ARCH|DEV|REVIEW|QA|DESIGN)\] ($VALID_TYPES): .{3,}"
PATTERN_WITHOUT_ROLE="^($VALID_TYPES): .{3,}"

# 先驗證格式
FORMAT_OK=0
if echo "$COMMIT_MSG" | grep -qE "$PATTERN_WITH_ROLE"; then
    FORMAT_OK=1
fi
if echo "$COMMIT_MSG" | grep -qE "$PATTERN_WITHOUT_ROLE"; then
    FORMAT_OK=1
fi

if [ $FORMAT_OK -eq 0 ]; then
    echo ""
    echo "❌ [commit-msg v3] Commit 訊息格式不正確！"
    echo ""
    echo "   你的訊息：$COMMIT_MSG"
    echo ""
    echo "   正確格式：[ROLE] type: 描述 （至少 3 個字元）"
    echo "   範例："
    echo "     [ARCH] plan: 設計玩家移動系統架構"
    echo "     [DEV] feat: 實作玩家跳躍功能 [Ponytail] rung=5"
    echo "     [DEV] fix: 修正碰撞偵測在斜面上的錯誤 ERR-001 [Ponytail] rung=5"
    echo "     [REVIEW] review: 審查玩家移動 PR"
    echo "     [QA] test: 驗證玩家移動測試全部通過"
    echo "     docs: 更新 README"
    echo ""
    echo "   可用 type: feat | fix | plan | review | test | docs | refactor | chore | style | perf | ci"
    echo ""
    exit 1
fi

# ——————————————————————————————————————
# 提取 type（處理有無 [ROLE] 前綴兩種格式）
# ——————————————————————————————————————
TYPE=$(echo "$COMMIT_MSG" | sed 's/^\[\(ARCH\|DEV\|REVIEW\|QA\|DESIGN\)\] //' | cut -d: -f1 | tr -d ' ')


exit 0
