#!/bin/sh
# ==========================================================
# hooks/pre-push  (v4 — 角色序列完整性強制)
# AI-Agnostic Pre-Push Hook for Godot 4 Project
#
# 觸發時機：執行 git push 前自動執行
# 作用：  最後一道防線，阻斷核心 workflow 文件缺失或 SOP 未完成的 push
# v2 新增功能：
#   - GAP-013 防範：push main 前確認 workflow.md / roles/ / hooks/ 存在
# v3 新增功能：
#   - SOP 完整性：sop-state.md 有 PENDING 步驟 → 阻斷 push（強制所有角色完成各自步驟）
# v4 新增功能：
#   - 角色序列：main push 前確認最近一輪包含 [DEV] + [REVIEW] + [QA] commit
#   - WARN: 若缺少 [DESIGN] commit（GDD 未更新）也提示
# ==========================================================

echo ""
echo "============================================================"
echo "[Pre-Push Hook v4] Push 前最終安全驗證..."
echo "============================================================"

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ——————————————————————————————————————
# [GAP-013 防範] 推送 main 前確認核心 Workflow 文件存在
# workflow.md / roles/ / hooks/ 是 workflow 的基礎設施
# 如果這些文件不存在，整個工作流就會崩潰（GAP-013 的根本原因）
# ——————————————————————————————————————
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo "[GAP-013 檢查] 確認核心 Workflow 文件存在於 main..."
    CORE_MISSING=0

    if ! git cat-file -e HEAD:workflow.md 2>/dev/null; then
        echo "❌ [GAP-013] workflow.md 不存在於 main 分支！"
        echo "   整個工作流將在下次 clone/reset 後失效。"
        echo "   修復：git checkout feature/xxx -- workflow.md && git commit && git push"
        CORE_MISSING=$((CORE_MISSING + 1))
    fi

    if ! git ls-tree HEAD roles/ 2>/dev/null | grep -q .; then
        echo "❌ [GAP-013] roles/ 目錄不存在於 main 分支！"
        echo "   角色定義文件缺失，多 Agent 工作流無法運作。"
        CORE_MISSING=$((CORE_MISSING + 1))
    fi

    if ! git ls-tree HEAD hooks/ 2>/dev/null | grep -q .; then
        echo "❌ [GAP-013] hooks/ 目錄不存在於 main 分支！"
        echo "   Git Hook 強制層缺失，所有機器層約束失效。"
        CORE_MISSING=$((CORE_MISSING + 1))
    fi

    if [ $CORE_MISSING -gt 0 ]; then
        echo ""
        echo "❌ 發現 $CORE_MISSING 個核心文件/目錄缺失，阻斷 Push 到 main！"
        echo "   請先補上缺失的文件再推送。"
        echo "   參考 ERROR_LOG.md GAP-013 的修復方法。"
        exit 1
    fi
    echo "   [PASS] 核心 Workflow 文件完整（workflow.md / roles/ / hooks/）"

    # ——————————————————————————————————————
    # [SOP 完整性] sop-state.md PENDING → 阻斷 push 到 main
    # 強制所有 §MOD SOP 角色步驟完成後才能 push（確保角色協同完整）
    # 注意：只在 main branch 阻斷；feature branch push 不受此限制
    # ——————————————————————————————————————
    if [ -f "docs/sop-state.md" ]; then
        SOP_PENDING=$(grep -cE '^\s*\|[^|]+\|[^|]+\|\s*PENDING\s*\|' docs/sop-state.md || echo "0")
        if [ "$SOP_PENDING" -gt 0 ]; then
            echo ""
            echo "❌ [SOP 強制] docs/sop-state.md 有 $SOP_PENDING 個 PENDING 步驟未完成！"
            echo "   Push 到 main 被阻斷：§MOD SOP 要求所有角色步驟完成後才能推送。"
            echo ""
            grep -E '^\s*\|[^|]+\|[^|]+\|\s*PENDING\s*\|' docs/sop-state.md | head -5
            echo ""
            echo "   完成全部 PENDING 步驟並更新 sop-state.md 後，再執行 git push。"
            exit 1
        fi
        echo "   [PASS] SOP 步驟全部完成（無 PENDING）"
    fi

    # ——————————————————————————————————————
    # [v4] 角色序列完整性：自上次 ARCH merge 後，必須存在 [DEV]+[REVIEW]+[QA]
    # 防止跳過 Reviewer 或 QA 步驟直接 push
    # ——————————————————————————————————————
    echo ""
    echo "[序列檢查] 驗證 Designer→Developer→Reviewer→QA 序列..."

    # 取得上次 ARCH merge commit 之後的所有 commit messages
    LAST_ARCH_MERGE=$(git log --oneline --format="%H %s" | grep "\[ARCH\].*merge\|merge.*\[ARCH\]" | head -1 | awk '{print $1}')
    if [ -n "$LAST_ARCH_MERGE" ]; then
        RECENT_COMMITS=$(git log --format="%s" "${LAST_ARCH_MERGE}..HEAD" 2>/dev/null)
    else
        RECENT_COMMITS=$(git log --format="%s" -20 2>/dev/null)
    fi

    SEQ_FAIL=0

    # 必須有 DEV commit
    if ! echo "$RECENT_COMMITS" | grep -q "^\[DEV\]"; then
        echo "❌ [序列] 缺少 [DEV] commit！Developer 必須在 push 前完成實作。"
        SEQ_FAIL=$((SEQ_FAIL + 1))
    else
        echo "   ✅ [DEV] commit 存在"
    fi

    # 必須有 REVIEW commit
    if ! echo "$RECENT_COMMITS" | grep -q "^\[REVIEW\]"; then
        echo "❌ [序列] 缺少 [REVIEW] commit！Reviewer 必須審查後才能 push。"
        SEQ_FAIL=$((SEQ_FAIL + 1))
    else
        echo "   ✅ [REVIEW] commit 存在"
    fi

    # 必須有 QA commit
    if ! echo "$RECENT_COMMITS" | grep -q "^\[QA\]"; then
        echo "❌ [序列] 缺少 [QA] commit！QA 必須驗收後才能 push。"
        SEQ_FAIL=$((SEQ_FAIL + 1))
    else
        echo "   ✅ [QA] commit 存在"
    fi

    # WARN: 缺少 DESIGN commit（GDD 可能未更新）
    if ! echo "$RECENT_COMMITS" | grep -q "^\[DESIGN\]"; then
        echo "⚠️  [序列 WARN] 缺少 [DESIGN] commit — GAME_DESIGN.md 可能未更新。"
        echo "   如本輪無 GDD 變更（純技術修復），可忽略此警告。"
    else
        echo "   ✅ [DESIGN] commit 存在"
    fi

    if [ $SEQ_FAIL -gt 0 ]; then
        echo ""
        echo "❌ [序列強制] $SEQ_FAIL 個必要角色步驟缺失，阻斷 Push！"
        echo "   補齊 [REVIEW] 和/或 [QA] commit 後再推送。"
        exit 1
    fi
    echo "   [PASS] 角色序列完整（DEV + REVIEW + QA）"

    # ——————————————————————————————————————
    # [警告] 直接 push 到 main 提示
    # ——————————————————————————————————————
    echo "⚠️  [警告] 直接 push 到 main 分支。"
    echo "   建議使用 feature 分支 + Pull Request 工作流。"
fi

echo ""
echo "[PASS] Pre-push 驗證通過。"
echo "============================================================"
echo ""
exit 0
