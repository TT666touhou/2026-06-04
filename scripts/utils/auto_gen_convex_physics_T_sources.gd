func _run() -> void:
	_hulls = _build_hulls()
	var tileset := load(TILESET_PATH) as TileSet
	if not tileset:
		push_error("[auto_gen] 無法載入 TileSet：" + TILESET_PATH)
		return

	var physics_layer_count := tileset.get_physics_layers_count()
	if physics_layer_count == 0:
		push_error("[auto_gen] TileSet 沒有 physics layer，請先在 TileSet 設定頁面新增。")
		return

	var t_source_count := 0
	var total_tile_count := 0

	for si in range(tileset.get_source_count()):
		var src := tileset.get_source(si) as TileSetAtlasSource
		if src == null:
			continue

		# 只處理 [T] 開頭的 Source（透明背景版）
		if not src.resource_name.begins_with("[T]"):
			continue

		t_source_count += 1
		print("[auto_gen] 處理 Source #", si, " : ", src.resource_name)

		var tile_count := src.get_tiles_count()
		for ti in range(tile_count):
			var coords := src.get_tile_id(ti)
			var key := str(coords.x) + ":" + str(coords.y)
			var tdata := src.get_tile_data(coords, 0)
			if tdata == null:
				continue

			if key in _hulls:
				# 設定凸包絡碰撞多邊形
				tdata.set_collision_polygons_count(0, 1)
				tdata.set_collision_polygon_points(0, 0, _hulls[key])
			else:
				# 無前景像素：清除碰撞（空格、全黑 tile）
				tdata.set_collision_polygons_count(0, 0)
			total_tile_count += 1

	var save_result := ResourceSaver.save(tileset, TILESET_PATH)
	if save_result != OK:
		push_error("[auto_gen] 儲存失敗，錯誤碼：" + str(save_result))
		return

	print("[auto_gen] ✅ 完成！共處理 ", t_source_count, " 個 [T] Source，",
			total_tile_count, " 個 tile。")
	print("[auto_gen] 請在 TileSet Editor 驗證碰撞形狀。")
